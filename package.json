{
  "name": "pier",
  "productName": "Pier",
  "version": "0.2.0",
  "description": "Pier — macOS menu-bar app and CLI for orchestrating local dev services across tmux.",
  "private": true,
  "main": "src/electron/main.js",
  "bin": {
    "pier": "bin/pier.js"
  },
  "scripts": {
    "postinstall": "node scripts/make-icons.js",
    "app": "electron .",
    "build:icons": "node scripts/make-icons.js",
    "build:app": "node scripts/build-app.js",
    "cli": "node bin/pier.js",
    "install:app": "node scripts/build-app.js --install",
    "install:skill": "node scripts/install-skill.js",
    "uninstall:skill": "node scripts/install-skill.js --uninstall",
    "open:app": "open dist/Pier.app",
    "start": "electron .",
    "test": "node --test tests/"
  },
  "keywords": [
    "development",
    "tmux",
    "menubar",
    "logs"
  ],
  "author": "vansickn",
  "license": "MIT",
  "devDependencies": {
    "electron": "^37.0.0"
  }
}
